# Marigold Studio — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------------------------------------------------------------------------
# Supabase — database, auth, storage.
# Get values from your Supabase project Settings → API.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SERVER ONLY — bypasses Row Level Security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# App / runtime
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# Optional — PM2 tuning (defaults shown in ecosystem.config.js)
# PM2_APP_NAME=marigold-studio
# PM2_MAX_MEMORY=1G

# ---------------------------------------------------------------------------
# Resend — outreach email sending (https://resend.com).
# Free tier: 100 emails/day, no credit card. Required to enable the Send
# button in the in-app Email Composer (otherwise it falls back to Copy HTML
# and mailto:).
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# Optional. Defaults to "The Marigold <onboarding@resend.dev>" — fine for
# development. For production, verify your domain on Resend and use e.g.
# "The Marigold <hello@themarigold.in>".
RESEND_FROM=

# Optional. Replies bounce to this address — usually your real inbox.
RESEND_REPLY_TO=

# ---------------------------------------------------------------------------
# Groq — Whisper transcription for Karaoke Reel word-level timestamps.
# Free tier: 7200 audio-seconds/day. No credit card needed.
# Get a key at https://console.groq.com → API Keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# NVIDIA NIM — primary LLM for content generation (calendar planning,
# single-post generation, captions, variations, blog posts, template
# concepts) AND for Whisper transcript correction in karaoke reels.
# Get a key at https://build.nvidia.com → API Catalog
# Models used: meta/llama-3.3-70b-instruct (general),
#              nvidia/llama-3.3-nemotron-super-49b-v1 (blog generation)
# ---------------------------------------------------------------------------
NVIDIA_API_KEY=
